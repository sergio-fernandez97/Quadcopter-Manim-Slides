{
  "permissions": {
    "allow": [
      "Bash(chmod:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push)",
      "Bash(git -C \"/Users/sergio.fernandez/Documents/personal/tesis /Quadcopter-Manim-Slides\" log --oneline -10)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(uv run manim-slides render slides/13_ilqr.py ILQRSlide)",
      "Bash(brew install:*)",
      "Bash(brew list:*)",
      "Bash(HOMEBREW_NO_AUTO_UPDATE=1 brew install:*)",
      "Bash(uv run:*)",
      "Bash(rm:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(sed:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__playwright__browser_resize",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_evaluate",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_press_key",
      "Skill(slide)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python .codex/hooks/read_hook.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .codex/hooks/auto_render.sh",
            "timeout": 300000
          }
        ]
      }
    ]
  }
}
